# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend Service Role Key (kept secret, used by Python backend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WhatsApp API (Meta Cloud API - 100% free for ~25 reports/month)
# 1. Go to https://developers.facebook.com → Create WhatsApp App
# 2. Get Phone Number ID from WhatsApp > API Setup
# 3. Generate permanent Access Token
# 4. Add your business number to the WhatsApp group, then get Group ID
META_ACCESS_TOKEN=your-permanent-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_GROUP_ID=your-group-id

# Timezone
TIMEZONE=Asia/Riyadh
