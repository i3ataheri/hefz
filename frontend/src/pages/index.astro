---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="app" id="app">
    <div class="bg-top"></div>
    <div class="header">
      <h1 class="header-title">حلقة تحفيظ القرآن الأستاذة هدى</h1>
      <p class="header-sub">مسموح التسجيل من الساعة ١ إلى ٣ بتوقيت مكة المكرمة</p>
    </div>
    <div class="status status--info" id="status-bar">
      <span class="status-icon">⏳</span>
      <div>
        <div class="status-title">جاري التحميل...</div>
        <div class="status-desc">يتم جلب البيانات يرجى الانتظار</div>
      </div>
    </div>
    <div class="member-section" id="member-section">
      <div class="empty-msg">جاري تحميل قائمة الأسماء...</div>
    </div>
    <div class="footer">وقت التسجيل: ١:٠٠ ظهرًا - ٣:٠٠ عصرًا بتوقيت مكة</div>
  </div>
</Layout>

<script>
const X_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c62828" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';
const WARN_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f57f17" stroke-width="2.5" stroke-linecap="round"><path d="M12 9v4m0 4h.01M10.29 3.86l-8.1 14c-.6 1.04.15 2.34 1.23 2.34h16.16c1.08 0 1.83-1.3 1.23-2.34l-8.1-14c-.6-1.04-2.06-1.04-2.66 0z"/></svg>';
const CLOCK_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1b5e20" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>';
const CHECK_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2e7d32" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>';

async function main() {
  const statusBar = document.getElementById('status-bar');
  const memberSection = document.getElementById('member-section');

  try {
    const mod = await import('../lib/supabase');
    const supabase = mod.supabase;
    if (!supabase) throw new Error('Supabase client is null');

    const today = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
    const [sResult, pmResult, mResult, rResult, mgrResult] = await Promise.allSettled([
      supabase.from('settings').select('value').eq('key', 'is_saturday_enabled').single(),
      supabase.from('priority_members').select('name').order('sort_order'),
      supabase.from('members').select('name'),
      supabase.from('registrations').select('name,created_at').eq('registered_date', today).order('created_at'),
      supabase.from('managers').select('name').order('sort_order'),
    ]);

    const satEnabled = sResult.status === 'fulfilled' ? (sResult.value.data?.value === true) : false;
    const priorityMembers = pmResult.status === 'fulfilled' ? (pmResult.value.data || []).map(p => p.name) : [];
    const prioritySet = new Set(priorityMembers);
    const allMembers = mResult.status === 'fulfilled' ? (mResult.value.data || []) : [];
    let regData = rResult.status === 'fulfilled' ? (rResult.value.data || []) : [];
    const managers = mgrResult.status === 'fulfilled' ? (mgrResult.value.data || []).map(m => m.name) : [];

    // Auto-cleanup old registrations before registration opens
    const _riyadhNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Riyadh' }));
    if (_riyadhNow.getHours() < 13 && regData.length > 0 && managers.length > 0) {
      try { await supabase.rpc('cleanup_old_registrations'); regData = []; } catch {}
    }

    const registeredSet = new Set(regData.map(r => r.name));
    const regOrder = {}
    regData.forEach((r, i) => { regOrder[r.name] = i });

    const now = new Date();
    const riyadhNow = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Riyadh' }));
    const riyadhH = riyadhNow.getHours();
    const riyadhDay = riyadhNow.getDay();
    const startDate = new Date('2026-06-24');
    const diffDays = Math.floor((riyadhNow - startDate) / (1000 * 60 * 60 * 24));
    const todayMgrIdx = managers.length > 0 ? ((diffDays % managers.length) + managers.length) % managers.length : -1;
    const todayManager = todayMgrIdx >= 0 ? managers[todayMgrIdx] : null;

    const h = riyadhH, day = riyadhDay;
    let status = 'open';
    if (day === 5) status = 'friday';
    else if (day === 6 && !satEnabled) status = 'saturday';
    else if (h < 13) status = 'before';
    else if (h >= 15) status = 'after';

    const X_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c62828" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';
    const WARN_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f57f17" stroke-width="2.5" stroke-linecap="round"><path d="M12 9v4m0 4h.01M10.29 3.86l-8.1 14c-.6 1.04.15 2.34 1.23 2.34h16.16c1.08 0 1.83-1.3 1.23-2.34l-8.1-14c-.6-1.04-2.06-1.04-2.66 0z"/></svg>';
    const CLOCK_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1b5e20" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>';
    const CHECK_ICON = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2e7d32" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>';

    const MSGS = {
      friday:   [X_ICON, '', 'النظام مغلق يوم الجمعة.', 'error'],
      saturday: [WARN_ICON, '', 'التسجيل مغلق اليوم (السبت). حاولي غدًا.', 'warning'],
      before:   [CLOCK_ICON, '', 'التسجيل من ١:٠٠ ظهرًا إلى ٣:٠٠ عصرًا.', 'info'],
      open:     [CHECK_ICON, 'التسجيل مفتوح الآن', 'اختاري اسمك من القائمة وسجّلي حضورك.', 'success'],
      after:    [X_ICON, 'انتهت فترة التسجيل', 'يمكن للمديرة نسخ التقرير من الأسفل.', 'error'],
    };
    const [icon, title, desc, type] = MSGS[status];
    statusBar.className = `status status--${type}`;
    const titleHtml = title ? `<div class="status-title">${title}</div>` : '';
    statusBar.innerHTML = `<span class="status-icon">${icon}</span><div>${titleHtml}<div class="status-desc">${desc}</div></div>`;

    let isOpen = status === 'open';
    const managerSet = new Set(managers);

    function sortMembers() {
      return [...allMembers].sort((a, b) => {
        const aReg = registeredSet.has(a.name);
        const bReg = registeredSet.has(b.name);
        if (aReg !== bReg) return aReg ? -1 : 1;
        if (!aReg) return a.name.localeCompare(b.name);

        const aMgr = managerSet.has(a.name);
        const bMgr = managerSet.has(b.name);
        const aToday = a.name === todayManager;
        const bToday = b.name === todayManager;
        const aPri = prioritySet.has(a.name);
        const bPri = prioritySet.has(b.name);

        const g = (isToday, isMgr, isPri) => isToday ? 0 : isMgr ? 1 : isPri ? 2 : 3;
        const ga = g(aToday, aMgr, aPri);
        const gb = g(bToday, bMgr, bPri);
        if (ga !== gb) return ga - gb;
        return (regOrder[a.name] ?? 0) - (regOrder[b.name] ?? 0);
      });
    }

    function renderItems() {
      return sortMembers().map(m => {
        const reg = registeredSet.has(m.name);
        return `<button class="name-item${reg ? ' registered' : ''}" data-name="${m.name}" ${reg ? 'disabled' : ''}>
          <span class="name-text">${m.name}</span>
          ${reg ? '<span class="name-badge">مسجّل</span>' : '<span class="name-radio"></span>'}
        </button>`;
      }).join('');
    }

    let selectedName = '';

    function render(keepSearch) {
      const prevScroll = memberSection.querySelector('.member-list')?.scrollTop ?? 0;
      const prevSearch = memberSection.querySelector('#search')?.value ?? '';

      memberSection.innerHTML = `
        <div class="search-box">
          <input type="text" id="search" class="search-input" placeholder="ابحثي عن اسمك..." autocomplete="off" />
        </div>
        <div class="member-list" id="member-list">${renderItems()}</div>
        <div id="selected-info" class="selected-info" style="display:none">
          <span class="selected-label">الاسم المختار:</span>
          <span class="selected-name" id="selected-name"></span>
        </div>
        <button id="submit-btn" class="submit-btn" ${!isOpen ? 'disabled' : ''}>${isOpen ? 'تسجيل الحضور' : 'غير متاح الآن'}</button>
        <div id="msg" class="msg" style="display:none"></div>
        <div id="report-section" class="report-section" style="display:none"></div>
      `;

      const ml = document.getElementById('member-list');
      if (ml) ml.scrollTop = prevScroll;

      const searchEl = document.getElementById('search');
      if (searchEl && keepSearch) {
        searchEl.value = prevSearch;
        if (prevSearch) doFilter(prevSearch);
      }

      bindEvents(keepSearch);
    }

    function doFilter(q) {
      const ml = document.getElementById('member-list');
      if (!ml) return;
      ml.querySelectorAll('.name-item').forEach(el => {
        const match = !q || el.dataset.name.toLowerCase().includes(q.toLowerCase());
        el.style.display = match ? '' : 'none';
      });
    }

    function scrollToSubmit() {
      setTimeout(() => {
        const btn = document.getElementById('submit-btn');
        if (btn) btn.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }

    function selectName(name) {
      selectedName = name;
      const nameEl = document.getElementById('selected-name');
      if (nameEl) nameEl.textContent = name;
      const infoEl = document.getElementById('selected-info');
      if (infoEl) infoEl.style.display = 'flex';
      document.querySelectorAll('.name-item').forEach(el => el.classList.remove('selected'));
      document.querySelector(`.name-item[data-name="${name}"]`)?.classList.add('selected');
      if (isOpen) {
        document.getElementById('submit-btn').disabled = false;
        scrollToSubmit();
      }
    }

    function bindEvents(savedSearch) {
      const searchEl = document.getElementById('search');
      if (searchEl) {
        searchEl.oninput = function() { doFilter(this.value.trim()); };
      }

      const ml = document.getElementById('member-list');
      if (ml) {
        ml.onclick = function(e) {
          var item = e.target.closest('.name-item');
          if (!item || item.classList.contains('registered') || item.disabled) return;
          document.querySelectorAll('.name-item').forEach(function(el) { el.classList.remove('selected'); });
          item.classList.add('selected');
          selectName(item.dataset.name);
        };
      }

      const submitBtn = document.getElementById('submit-btn');
      if (submitBtn) {
        submitBtn.onclick = async function() {
          if (!selectedName || !isOpen) return;
          submitBtn.disabled = true;
          submitBtn.textContent = 'جاري التسجيل...';
          const msgEl = document.getElementById('msg');
          try {
            const now = new Date().toISOString();
            const { error } = await supabase.from('registrations').insert({
              name: selectedName,
              registered_date: today,
            });
            if (error) {
              msgEl.textContent = error.code === '23505' ? 'هذا الاسم مسجل مسبقًا اليوم.' : 'حدث خطأ. حاولي مرة أخرى.';
              msgEl.className = 'msg msg--error';
              msgEl.style.display = 'block';
              submitBtn.disabled = false;
              submitBtn.textContent = 'تسجيل الحضور';
              return;
            }
            const savedName = selectedName;
            selectedName = '';
            registeredSet.add(savedName);
            regOrder[savedName] = regData.length;
            regData.push({ name: savedName, created_at: now });
            render(true);
            const newMsg = document.getElementById('msg');
            if (newMsg) {
              newMsg.textContent = 'تم تسجيل ' + savedName + '!';
              newMsg.className = 'msg msg--success';
              newMsg.style.display = 'block';
            }
          } catch {
            msgEl.textContent = 'خطأ في الاتصال. تحققي من اتصالك.';
            msgEl.className = 'msg msg--error';
            msgEl.style.display = 'block';
            submitBtn.disabled = false;
            submitBtn.textContent = 'تسجيل الحضور';
          }
        };
      }
    }

    render();

    function checkTimeAndUpdate() {
      const n = new Date();
      var rH = n.getUTCHours() + 3;
      var rDay = n.getUTCDay();
      if (rH >= 24) { rH -= 24; rDay = (rDay + 1) % 7; }
      var newStatus = 'open';
      if (rDay === 5) newStatus = 'friday';
      else if (rDay === 6 && !satEnabled) newStatus = 'saturday';
      else if (rH < 13) newStatus = 'before';
      else if (rH >= 15) newStatus = 'after';

      if (newStatus !== status) {
        status = newStatus;
        isOpen = status === 'open';
        document.getElementById('submit-btn').disabled = !isOpen;
        document.getElementById('submit-btn').textContent = isOpen ? 'تسجيل الحضور' : 'غير متاح الآن';
        const [icon, title, desc, type] = MSGS[status];
        statusBar.className = 'status status--' + type;
        statusBar.innerHTML = '<span class="status-icon">' + icon + '</span><div>' + (title ? '<div class="status-title">' + title + '</div>' : '') + '<div class="status-desc">' + desc + '</div></div>';
        if (status === 'after') { try { showReportSection(); } catch(e) {} }
      }
    }

    if (status === 'before' || status === 'open') {
      setInterval(checkTimeAndUpdate, 1000);
    }

    if (status === 'after') {
      try { showReportSection(); } catch(e) {
        statusBar.className = 'status status--error';
        statusBar.innerHTML = '<span class="status-icon">' + X_ICON + '</span><div><div class="status-title">خطأ في التقرير</div><div class="status-desc">' + (e.message || '') + '</div></div>';
      }
    }

    function buildReportText() {
      var hijri = new Date().toLocaleDateString('ar-SA', { calendar: 'islamic', weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      var sorted = sortMembers().filter(function(m) { return registeredSet.has(m.name); });
      var lines = [];
      lines.push('اليوم ' + hijri);
      lines.push('');
      var num = 0;
      for (var i = 0; i < sorted.length; i++) {
        var m = sorted[i];
        if (registeredSet.has(m.name)) {
          num++;
          var tag = '';
          if (m.name === todayManager) tag = ' (المديرة)';
          else if (managerSet.has(m.name)) tag = ' (مديرة)';
          lines.push(num + '. ' + m.name + tag);
        }
      }
      return lines.join('\n');
    }

    function showReportSection() {
      var section = document.getElementById('report-section');
      if (!section) return;
      section.style.display = 'block';
      var presentCount = registeredSet.size;

      section.innerHTML =
        '<div class="report-summary">' +
          '<div class="report-title">تقرير اليوم</div>' +
          '<div class="report-count">الحاضرات: ' + presentCount + ' / ' + allMembers.length + '</div>' +
        '</div>' +
        '<div class="manager-verify">' +
          '<p class="verify-hint">لنسخ التقرير، أدخلي رمز التفعيل</p>' +
          '<div class="verify-row">' +
            '<input type="password" id="pin-input" class="pin-input" placeholder="الرمز" maxlength="4" inputmode="numeric" />' +
            '<button id="pin-verify-btn" class="verify-btn">تأكيد</button>' +
          '</div>' +
          '<div id="pin-error" class="pin-error" style="display:none">الرمز غير صحيح</div>' +
        '</div>' +
        '<div id="report-content" class="report-content" style="display:none">' +
          '<textarea id="report-text" class="report-text" readonly></textarea>' +
          '<div class="btn-row">' +
            '<button id="share-btn" class="share-btn">مشاركة</button>' +
            '<button id="copy-btn" class="copy-btn">نسخ التقرير</button>' +
          '</div>' +
          '<div id="copy-msg" class="copy-msg" style="display:none">تم النسخ!</div>' +
        '</div>';

      var pinInput = document.getElementById('pin-input');
      var pinBtn = document.getElementById('pin-verify-btn');
      var pinError = document.getElementById('pin-error');

      if (pinBtn) {
        pinBtn.onclick = async function() {
          var entered = pinInput ? pinInput.value.trim() : '';
          if (!entered) { pinError.style.display = 'block'; return; }
          pinBtn.disabled = true;
          var valid = false;
          try {
            var { data, error } = await supabase.rpc('verify_manager_pin', { input_pin: entered });
            if (!error && data === true) valid = true;
          } catch(e) {}
          pinBtn.disabled = false;
          if (valid) {
            pinError.style.display = 'none';
            document.querySelector('.manager-verify').style.display = 'none';
            var rc = document.getElementById('report-content');
            if (rc) rc.style.display = 'block';
            var rt = document.getElementById('report-text');
            if (rt) rt.value = buildReportText();
            var copyMsg = document.getElementById('copy-msg');
            if (copyMsg) copyMsg.style.display = 'none';
          } else {
            pinError.style.display = 'block';
          }
        };
      }

      var copyBtn = document.getElementById('copy-btn');
      if (copyBtn) {
        copyBtn.onclick = function() {
          var textarea = document.getElementById('report-text');
          textarea.select();
          textarea.setSelectionRange(0, 99999);
          navigator.clipboard.writeText(textarea.value);
          document.getElementById('copy-msg').style.display = 'block';
        };
      }

      var shareBtn = document.getElementById('share-btn');
      if (shareBtn) {
        shareBtn.onclick = function() {
          var text = document.getElementById('report-text').value;
          if (navigator.share) {
            navigator.share({ text: text });
          } else {
            navigator.clipboard.writeText(text);
            document.getElementById('copy-msg').style.display = 'block';
          }
        };
      }
    }

  } catch (err) {
    statusBar.className = 'status status--error';
    statusBar.innerHTML = `<span class="status-icon">${X_ICON}</span><div><div class="status-title">خطأ</div><div class="status-desc">${err.message || 'حدث خطأ غير متوقع'}</div></div>`;
    memberSection.innerHTML = '<div class="empty-msg">تعذر تحميل الصفحة</div>';
  }
}

main();
</script>

<style lang="scss" is:global>
@use '../styles/variables' as *;
$font-alexandria: 'Alexandria', sans-serif;
$font-cairo: 'Cairo', sans-serif;
$font-almarai: 'Almarai', sans-serif;

.app { max-width: 440px; margin: 0 auto; padding: 0 $spacing-md $spacing-xl; min-height: 100vh; display: flex; flex-direction: column; position: relative; overflow-x: hidden; }
.bg-top { position: fixed; top: 0; left: 0; right: 0; height: 280px; background: linear-gradient(180deg, #fce8ee 0%, #fdf2f5 40%, transparent 100%); z-index: 0; pointer-events: none; }
.bg-top::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 100%; background: radial-gradient(ellipse at 50% 0%, rgba($color-primary-light, 0.15) 0%, transparent 60%); }
.header { position: relative; z-index: 1; text-align: center; padding: $spacing-lg 0 $spacing-md; }
.header-title { font-family: $font-alexandria; font-size: 1.3rem; font-weight: 800; color: $color-primary-dark; line-height: 1.4; margin-bottom: $spacing-xs; letter-spacing: 0.5px; }
.header-sub { font-family: $font-almarai; font-size: $font-size-sm; color: $color-text-light; font-weight: 300; }
.status { position: relative; z-index: 1; display: flex; align-items: center; gap: $spacing-md; padding: $spacing-md $spacing-lg; border-radius: 16px; margin-bottom: $spacing-md; background: $color-bg-card; box-shadow: $shadow-sm; border: 1px solid $color-border; }
.status .status-icon { font-size: 1.4rem; flex-shrink: 0; }
.status .status-title { font-family: $font-alexandria; font-size: $font-size-base; font-weight: 700; margin-bottom: 2px; }
.status .status-desc { font-family: $font-almarai; font-size: $font-size-sm; color: $color-text-light; }
.status--success { border-right: 3px solid $color-success; } .status--success .status-title { color: $color-success; }
.status--error { border-right: 3px solid $color-error; } .status--error .status-title { color: $color-error; }
.status--warning { border-right: 3px solid $color-warning; } .status--warning .status-title { color: $color-warning; }
.status--info { border-right: 3px solid $color-primary; } .status--info .status-title { color: $color-primary; }
.member-section { position: relative; z-index: 1; flex: 1; }
.empty-msg { text-align: center; padding: $spacing-xl; color: $color-text-light; font-family: $font-almarai; }
.search-box { position: sticky; top: 0; z-index: 2; padding: $spacing-sm 0 $spacing-sm; background: $color-bg; }
.search-input { width: 100%; padding: 14px $spacing-md; font-family: $font-almarai; font-size: $font-size-base; border: 2px solid $color-border; border-radius: 14px; background: $color-bg-card; transition: border-color 0.2s, box-shadow 0.2s; }
.search-input:focus { border-color: $color-primary; box-shadow: 0 0 0 3px rgba($color-primary, 0.1); outline: none; }
.search-input:disabled { opacity: 0.5; }
.search-input::placeholder { color: $color-text-light; font-weight: 300; }
.member-list { flex: 1; overflow-y: auto; padding: $spacing-xs 0 $spacing-md; display: flex; flex-direction: column; gap: 6px; }
.name-item { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 12px $spacing-md; font-family: $font-cairo; font-size: $font-size-base; font-weight: 600; border: 1px solid transparent; border-radius: 12px; background: $color-bg-card; color: $color-text; text-align: right; transition: all 0.15s; -webkit-tap-highlight-color: transparent; touch-action: manipulation; box-shadow: $shadow-sm; position: relative; overflow: hidden; }
